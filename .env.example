# Server Port
PORT=3000

# PostgreSQL Vector Database (e.g., Neon Cloud PostgreSQL or any instance with pgvector extension)
DATABASE_URL=your_postgresql_database_url_here

# LLM Provider - Groq Cloud API Key (for LLM reasoning)
GROQ_API_KEY=your_groq_api_key_here

# Embeddings - Hugging Face API Key (for sentence-transformers/all-MiniLM-L6-v2 embeddings)
HF_API_KEY=your_hugging_face_api_key_here

# Cache & Storage - Upstash Redis (Serverless Redis)
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here
